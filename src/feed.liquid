---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" ><generator uri="https://jekyllrb.com/" version="4.2.2">Jekyll</generator><link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml" /><link href="{{ site.url }}/" rel="alternate" type="text/html" /><updated>{{ buildTime | date_to_xmlschema }}</updated><id>{{ site.url }}/feed.xml</id><title type="html">{{ site.title | escape }}</title><subtitle>{{ site.description | escape }}</subtitle><author><name>{{ site.author | escape }}</name></author>{%- assign posts = collections.posts | reverse -%}{%- for post in posts -%}<entry><title type="html">{{ post.data.title | escape }}</title><link href="{{ site.url }}{{ post.url }}" rel="alternate" type="text/html" title="{{ post.data.title | escape }}" /><published>{{ post.date | date_to_xmlschema }}</published><updated>{{ post.date | date_to_xmlschema }}</updated><id>{{ site.url }}{{ post.url | remove: '.html' }}</id><content type="html" xml:base="{{ site.url }}{{ post.url }}"><![CDATA[{{ post.templateContent }}]]></content><author><name>{{ site.author | escape }}</name></author>{%- for tag in post.data.tags -%}<category term="{{ tag }}" />{%- endfor -%}<summary type="html"><![CDATA[{{ post.data.excerpt | markdownify | strip_html | strip }}]]></summary></entry>{%- endfor -%}</feed>
